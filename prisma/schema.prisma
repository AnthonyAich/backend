// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  firstName String 
  lastName  String
  email     String @unique
  password  String
  roleId   Int
  Role    Role @relation(fields: [roleId], references: [id])
  UserClass UserClass[]
  Author    Author[]
  Attendee  Attendee[]
}

model Class {
  id        Int     @id @default(autoincrement())
  name      String
  description String
  UserClass UserClass[]
  ClassCourse ClassCourse[]

}

model Role {
  id        Int     @id @default(autoincrement())
  name      String
  User User[]
}

model ClassRole {
  id        Int     @id @default(autoincrement())
  name      String
  UserClass UserClass[]
  Attendee Attendee[]
}

model UserClass {
  id        Int     @id @default(autoincrement())
  userId    Int
  User      User    @relation(fields: [userId], references: [id])
  classId   Int
  Class     Class   @relation(fields: [classId], references: [id])
  roleId    Int
  ClassRole      ClassRole @relation(fields: [roleId], references: [id])
}

model Course {
  id       Int     @id @default(autoincrement())
  name     String
  description String
  ClassCourse ClassCourse[]
  Module Module[]
  Author Author[]
}

model ClassCourse {
  id        Int     @id @default(autoincrement())
  classId   Int
  Class     Class   @relation(fields: [classId], references: [id])
  courseId  Int
  Course   Course @relation(fields: [courseId], references: [id])
}

model Module {
  id       Int     @id @default(autoincrement())
  courseId Int
  Course   Course  @relation(fields: [courseId], references: [id])
  name     String
  description String
}

model Author {
  id       Int     @id @default(autoincrement())
  courseId Int
  Course   Course  @relation(fields: [courseId], references: [id])
  userId Int
  User    User    @relation(fields: [userId], references: [id])
}

model MeetUp {
  id       Int     @id @default(autoincrement())
  name     String
  description String
  meetupTime     DateTime
  spots   Int
  Attendee Attendee[]
}

model Attendee {
  id       Int     @id @default(autoincrement())
  userId   Int
  User     User    @relation(fields: [userId], references: [id])
  meetupId Int
  MeetUp   MeetUp  @relation(fields: [meetupId], references: [id])
  roleId   Int
  ClassRole     ClassRole    @relation(fields: [roleId], references: [id])
}